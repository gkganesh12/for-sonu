---
import { beginning } from '../content';

// Star coordinates tracing a gentle "S" — for Sonu / Sakshi
const points = [
  [152, 34],
  [112, 18],
  [70, 30],
  [50, 66],
  [68, 100],
  [112, 112],
  [146, 136],
  [150, 176],
  [118, 206],
  [72, 210],
  [42, 190],
];
const polyline = points.map((p) => p.join(',')).join(' ');
---

<section class="scene" id="beginning">
  <div class="scene-inner">
    <span class="chapter-tag" data-reveal>{beginning.tag}</span>
    <h2 data-reveal>{beginning.heading}</h2>
    {beginning.paragraphs.map((p) => <p data-reveal set:html={p.replace(/\*(.+?)\*/g, '<em>$1</em>')} />)}

    <svg
      class="constellation"
      viewBox="0 0 200 240"
      role="img"
      aria-label="A constellation of stars in the shape of the letter S"
    >
      <polyline class="line" points={polyline}></polyline>
      {points.map(([x, y], i) => (
        <circle class="node" cx={x} cy={y} r={i % 3 === 0 ? 3.4 : 2.4}></circle>
      ))}
    </svg>
    <p class="constellation-caption" data-reveal>{beginning.constellationCaption}</p>
  </div>
</section>
