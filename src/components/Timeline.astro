---
import { timeline } from '../content';
---

<section class="scene" id="timeline">
  <div class="scene-inner">
    <span class="chapter-tag" data-reveal>{timeline.tag}</span>
    <h2 data-reveal>{timeline.heading}</h2>
    <p data-reveal>{timeline.intro}</p>

    <ol class="timeline">
      <div class="thread" aria-hidden="true"></div>
      {timeline.milestones.map((m) => (
        <li>
          <span class="dot" aria-hidden="true"></span>
          <span class="when">{m.when}</span>
          <h3>{m.label}</h3>
          <p>{m.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
