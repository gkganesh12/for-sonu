---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { moments } from '../content';

// Drop photos into src/assets/moments/ and they appear here automatically.
// The file name becomes the caption: "goa-trip.jpg" → "goa trip".
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/moments/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const photos = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => ({
    src: mod.default,
    caption: path
      .split('/')
      .pop()!
      .replace(/\.[^.]+$/, '')
      .replace(/[-_]+/g, ' '),
  }));
---

<section class="scene" id="moments">
  <div class="scene-inner">
    <span class="chapter-tag" data-reveal>{moments.tag}</span>
    <h2 data-reveal>{moments.heading}</h2>
    <p data-reveal>{moments.intro}</p>

    <div class="polaroids">
      {photos.length > 0
        ? photos.map((photo, i) => (
            <button
              class="polaroid"
              type="button"
              data-caption={photo.caption}
              style={`--float-delay: ${(i % 5) * 0.9}s`}
              aria-label={`Open photo: ${photo.caption}`}
            >
              <Image src={photo.src} alt={photo.caption} width={640} height={640} />
              <span class="caption">{photo.caption}</span>
            </button>
          ))
        : moments.placeholderCaptions.map((caption, i) => (
            <div class="polaroid placeholder" style={`--float-delay: ${(i % 5) * 0.9}s`}>
              <span class="frame" aria-hidden="true">✶</span>
              <span class="caption">{caption}</span>
            </div>
          ))}
    </div>

    {photos.length === 0 && <p class="placeholder-note">{moments.placeholderNote}</p>}
  </div>
</section>

<dialog id="lightbox" aria-label="Photo viewer">
  <button class="lb-close" type="button" aria-label="Close">×</button>
  <img alt="" />
  <p class="lb-caption"></p>
</dialog>
