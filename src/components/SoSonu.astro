---
import { soSonu } from '../content';
---

<section class="scene" id="so-sonu">
  <div class="scene-inner">
    <span class="chapter-tag" data-reveal>{soSonu.tag}</span>
    <h2 data-reveal>{soSonu.heading}</h2>
    <p data-reveal>{soSonu.intro}</p>

    <div class="cards">
      {soSonu.cards.map((card) => (
        <button class="card" type="button" aria-label={`${card.title} — tap to flip`}>
          <span class="card-inner">
            <span class="card-face front">
              <span class="icon">
                {card.icon}
                {card.steam && (
                  <span class="steam" aria-hidden="true"><i></i><i></i><i></i></span>
                )}
              </span>
              <span class="title">{card.title}</span>
              {card.meter && (
                <>
                  <span class="meter"><span class="fill"></span></span>
                  <span class="meter-label">∞ words / day</span>
                </>
              )}
              <span class="tap">tap</span>
            </span>
            <span class="card-face back">{card.back}</span>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>
