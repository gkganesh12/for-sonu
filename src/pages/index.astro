---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/caveat/500.css';
import '@fontsource/caveat/700.css';
import '@fontsource-variable/inter';
import '../styles/quest.css';

import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { site } from '../content';

// Photos drop-zone: src/assets/moments/ — filename becomes the caption,
// numeric prefixes control order and are stripped.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/moments/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const photos = await Promise.all(
  Object.entries(modules)
    .sort(([a], [b]) => a.localeCompare(b))
    .map(async ([path, mod]) => {
      const img = await getImage({ src: mod.default, width: 640, height: 640, fit: 'cover' });
      return {
        src: img.src,
        caption: path
          .split('/')
          .pop()!
          .replace(/\.[^.]+$/, '')
          .replace(/^\d+[-_ ]*/, '')
          .replace(/[-_]+/g, ' '),
      };
    })
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={site.description} />
    <meta name="theme-color" content="#fce8ef" />
    <meta property="og:title" content={site.title} />
    <meta property="og:description" content={site.description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{site.title}</title>
  </head>
  <body>
    <div id="bg-back"></div>
    <div id="bg-front"></div>

    <div id="level-chip">for sakshi ✨</div>
    <button id="music-toggle" type="button" aria-label="Toggle music">♪</button>

    <div id="app">
      <main id="scene-container"></main>
    </div>

    <script type="application/json" id="photo-data" set:html={JSON.stringify(photos)} />
    <script>
      import '../scripts/quest';
    </script>
  </body>
</html>
